#include <check.h>
#include <stdlib.h>
#include <stdio.h>
#include <string.h>
#include <sys/stat.h>
#include <unistd.h>

START_TEST(test_shell_injection_in_filenames)
{
    /* Invariant: Shell metacharacters in path variables must NOT cause
       arbitrary command execution when passed to ldms-ibnet-sampler-gen */
    const char *payloads[] = {
        "$(touch /tmp/pwned_ibnet)",       /* command substitution */
        "; touch /tmp/pwned_ibnet ;",      /* semicolon injection */
        "valid_topology_name",             /* benign input */
        "name`touch /tmp/pwned_ibnet`end", /* backtick injection */
    };
    int num_payloads = sizeof(payloads) / sizeof(payloads[0]);

    /* Remove marker file if it exists */
    unlink("/tmp/pwned_ibnet");

    for (int i = 0; i < num_payloads; i++) {
        char cmd[1024];
        /* Invoke the script with adversarial input as an argument that
           influences the file path variables (lo/pname/dname/aname/lname).
           We pass it as --prefix which feeds into path construction.
           The script may fail due to missing IB data, but it must NOT
           execute injected commands. */
        snprintf(cmd, sizeof(cmd),
                 "python3 ldms/src/sampler/ibnet/scripts/ldms-ibnet-sampler-gen "
                 "--prefix '%s' 2>/dev/null; true", payloads[i]);
        system(cmd);

        /* The security invariant: no injected command was executed */
        struct stat st;
        int exists = (stat("/tmp/pwned_ibnet", &st) == 0);
        ck_assert_msg(!exists,
                      "Shell injection succeeded with payload: %s", payloads[i]);
    }

    unlink("/tmp/pwned_ibnet");
}
END_TEST

Suite *security_suite(void)
{
    Suite *s;
    TCase *tc_core;

    s = suite_create("Security");
    tc_core = tcase_create("Core");

    tcase_set_timeout(tc_core, 30);
    tcase_add_test(tc_core, test_shell_injection_in_filenames);
    suite_add_tcase(s, tc_core);

    return s;
}

int main(void)
{
    int number_failed;
    Suite *s;
    SRunner *sr;

    s = security_suite();
    sr = srunner_create(s);

    srunner_run_all(sr, CK_NORMAL);
    number_failed = srunner_ntests_failed(sr);
    srunner_free(sr);

    return (number_failed == 0) ? EXIT_SUCCESS : EXIT_FAILURE;
}