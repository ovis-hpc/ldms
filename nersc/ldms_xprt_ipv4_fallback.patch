diff --git a/ldms/src/core/ldms_xprt.c b/ldms/src/core/ldms_xprt.c
index f4b2f470a..e190109a1 100644
--- a/ldms/src/core/ldms_xprt.c
+++ b/ldms/src/core/ldms_xprt.c
@@ -4629,13 +4629,19 @@ int ldms_xprt_listen_by_name(ldms_t x, const char *host, const char *port_no,
 	if (rc)
 		return EHOSTUNREACH;
 	ai = NULL;
-	/* Prefer the first IPv6 address */
-	for (aitr = ai_list; aitr; aitr = aitr->ai_next) {
-		if (aitr->ai_family == AF_INET6) {
-			ai = aitr;
-			break;
-		}
-	}
+        /* Prefer IPv6, fall back to IPv4 if IPv6 is unavailable */
+        for (aitr = ai_list; aitr; aitr = aitr->ai_next) {
+                int test_sock = socket(aitr->ai_family, SOCK_STREAM, 0);
+                if (test_sock < 0)
+                        continue; /* this family not supported, skip */
+                close(test_sock);
+                if (aitr->ai_family == AF_INET6) {
+                        ai = aitr;
+                        break;
+                }
+                if (aitr->ai_family == AF_INET && !ai)
+                        ai = aitr; /* save IPv4 as fallback */
+        }
 	if (!ai)
 		ai = ai_list;
 	rc = ldms_xprt_listen(x, ai->ai_addr, ai->ai_addrlen, cb, cb_arg);
